TELEGRAM_BOT_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_openai_api_key

# LLM settings
OPENAI_MODEL=gpt-5.4-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_OUTPUT_TOKENS=800

# Memory settings
MAX_SHORT_TERM_MESSAGES=20
LONG_TERM_TOP_K=4
STORE_CHUNK_SIZE=1200
STORE_CHUNK_OVERLAP=200
CHROMA_PATH=data/chroma
UPLOADS_PATH=data/uploads

# Optional custom instructions for the assistant.
OPENAI_SYSTEM_PROMPT=Ты полезный Telegram-бот с краткосрочной и долговременной памятью. Используй только то, что есть в текущем диалоге и в найденных фрагментах из долговременной памяти. Если данных недостаточно, честно скажи об этом и не выдумывай факты. Отвечай на языке пользователя.
